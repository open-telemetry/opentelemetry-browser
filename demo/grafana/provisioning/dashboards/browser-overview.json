    {
      "id": 29,
      "title": "Web Vitals",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": true,
      "panels": [
        {
          "id": 7,
          "title": "Overall — Good",
          "type": "gauge",
          "gridPos": { "h": 6, "w": 8, "x": 0, "y": 33 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "red", "value": null },
                  { "color": "yellow", "value": 50 },
                  { "color": "green", "value": 75 }
                ]
              }
            }
          },
          "options": {
            "reduceOptions": { "calcs": ["lastNotNull"] },
            "showThresholdMarkers": true
          },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "prometheus" },
              "expr": "sum(browser_web_vital_milliseconds_count{browser_web_vital_rating=\"good\"}) / sum(browser_web_vital_milliseconds_count) * 100",
              "refId": "A"
            }
          ]
        },
