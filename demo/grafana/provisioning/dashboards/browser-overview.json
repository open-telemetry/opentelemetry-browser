      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.75, sum by (le) (rate(browser_web_vital_milliseconds_bucket{browser_web_vital_name=\"ttfb\"}[5m])))",
          "legendFormat": "TTFB p75",
          "refId": "A"
