{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "schedule": ["before 8am on Monday"],
  "rebaseWhen": "behind-base-branch",
  // Override :ignoreModulesAndTests (via config:base) which adds **/examples/** by default
  "ignorePaths": ["**/node_modules/**", "**/vendor/**", "**/test/**", "**/tests/**", "**/__tests__/**", "**/fixtures/**"],
  "ignoreDeps": ["@types/node", "node", "npm"],
  "labels": ["dependencies"],
  "postUpdateOptions": ["npmDedupe"],
  "rangeStrategy": "bump",
  "separateMajorMinor": false,
  "packageRules": [
    {
      "description": "GitHub Actions",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "All dependencies",
      "matchDepTypes": ["dependencies", "devDependencies"],
      "groupName": "dependencies"
    },
    {
      "description": "OpenTelemetry",
      "matchDepNames": ["@opentelemetry/**"],
      "groupName": "opentelemetry"
    }
  ]
}
